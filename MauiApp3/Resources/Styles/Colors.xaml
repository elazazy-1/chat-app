<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Note: For Android please see also Platforms\Android\Resources\values\colors.xml -->

    <Color x:Key="Primary">#2563EB</Color>
    <Color x:Key="PrimaryDark">#1E40AF</Color>
    <Color x:Key="PrimaryDarkText">#0F172A</Color>
    <Color x:Key="Secondary">#E2E8F0</Color>
    <Color x:Key="SecondaryDarkText">#475569</Color>
    <Color x:Key="Tertiary">#1D4ED8</Color>

    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Magenta">#D600AA</Color>
    <Color x:Key="MidnightBlue">#0F172A</Color>
    <Color x:Key="OffBlack">#1f1f1f</Color>

    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>

    <!-- Chat-specific colors -->
    <Color x:Key="ChatBubbleSent">#E0F2FE</Color>
    <Color x:Key="ChatBubbleReceived">#FFFFFF</Color>
    <Color x:Key="ChatBackground">#F2F5FB</Color>
    <Color x:Key="AccentBlue">#2563EB</Color>
    <Color x:Key="SystemGray">#94A3B8</Color>
    <Color x:Key="OnlineDot">#22C55E</Color>
    <Color x:Key="UnreadBadge">#EF4444</Color>
    <Color x:Key="InputBarBg">#F8FAFC</Color>
    <Color x:Key="HeaderBg">#F1F5F9</Color>
    <Color x:Key="CardBg">#FFFFFF</Color>
    <Color x:Key="SoftShadow">#14000000</Color>
    <Color x:Key="JoinGradientStart">#DCEBFF</Color>
    <Color x:Key="JoinGradientEnd">#F8FAFC</Color>

    <!-- App theme colors -->
    <Color x:Key="AppDarkBlue">#0F172A</Color>
    <Color x:Key="AppMediumBlue">#1E293B</Color>
    <Color x:Key="AppAccentBlue">#2563EB</Color>
    <Color x:Key="AppLightBlue">#DBEAFE</Color>
    <Color x:Key="AppBackground">#F5F7FB</Color>
    <Color x:Key="AppSurface">#FFFFFF</Color>
    <Color x:Key="AppSurfaceAlt">#F1F5F9</Color>
    <Color x:Key="AppTextPrimary">#0F172A</Color>
    <Color x:Key="AppTextSecondary">#475569</Color>
    <Color x:Key="AppTextHint">#94A3B8</Color>
    <Color x:Key="AppDivider">#E2E8F0</Color>
    <Color x:Key="HeaderSubtext">#B6C2D1</Color>
    <Color x:Key="HeaderIconBg">#1E2A44</Color>
    <Color x:Key="ChatSystemMessage">#E2E8F0</Color>

    <SolidColorBrush x:Key="ChatBubbleSentBrush" Color="{StaticResource ChatBubbleSent}"/>
    <SolidColorBrush x:Key="ChatBubbleReceivedBrush" Color="{StaticResource ChatBubbleReceived}"/>
    <SolidColorBrush x:Key="ChatBackgroundBrush" Color="{StaticResource ChatBackground}"/>
    <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource AccentBlue}"/>
    <SolidColorBrush x:Key="SoftShadowBrush" Color="{StaticResource SoftShadow}"/>
    <SolidColorBrush x:Key="AppSurfaceAltBrush" Color="{StaticResource AppSurfaceAlt}"/>
    <SolidColorBrush x:Key="AppDividerBrush" Color="{StaticResource AppDivider}"/>

    <LinearGradientBrush x:Key="HeaderGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource AppDarkBlue}" Offset="0.0" />
        <GradientStop Color="{StaticResource AppMediumBlue}" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="JoinBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource JoinGradientStart}" Offset="0.0" />
        <GradientStop Color="{StaticResource JoinGradientEnd}" Offset="1.0" />
    </LinearGradientBrush>
</ResourceDictionary>